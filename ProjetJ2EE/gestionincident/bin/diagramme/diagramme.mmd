    class INotifiable {
        <<interface>>
        +recevoirNotification(notification : Notification) void
        +consulterNotifications() List~Notification~
        +getNombreNotificationsNonLues() int
    }

    class IAuthentifiable {
        <<interface>>
        +seConnecter(email : String, motDePasse : String) boolean
        +seDeconnecter() void
        +changerMotDePasse(ancien : String, nouveau : String) boolean
        +estActif() boolean
    }

    class IReportable {
        <<interface>>
        +soumettreIncident(incident : Incident) boolean
        +consulterMesIncidents() List~Incident~
        +annulerIncident(idIncident : Long) boolean
        +donnerFeedback(idIncident : Long, feedback : Feedback) boolean
    }

    class IStatistiques {
        <<interface>>
        +getStatistiques() Map~String_Object~
        +getTauxResolution() double
        +getTempsResolutionMoyen() double
    }

