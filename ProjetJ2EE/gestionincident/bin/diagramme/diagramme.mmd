    %% ============================================================
    %%                        RELATIONS
    %% ============================================================

    %% Héritage
    Utilisateur <|-- Employe
    Utilisateur <|-- Technicien
    Utilisateur <|-- DSI

    %% Implémentation interfaces
    Utilisateur ..|> INotifiable
    Utilisateur ..|> IAuthentifiable
    Employe ..|> IReportable
    Technicien ..|> IStatistiques
    DSI ..|> IStatistiques

    %% Associations
    Utilisateur "*" --> "1" Ville : estSituéDans

    Incident "1" --> "1" Employe : soumisParr
    Incident "1" --> "1" Materiel : concerneLe
    Incident "1" --> "1" CategorieIncident : estClassifiéPar
    Incident "1" --> "1" Ville : estLocaliséDans

    Affectation "*" --> "1" Incident : concerneL
    Affectation "*" --> "1" Technicien : estAssignéeA

    Notification "*" --> "1" Utilisateur : estDestinéeA
    Notification "*" --> "1" Incident : concerneL

    Feedback "0..1" --> "1" Incident : evalueL
    Feedback "*" --> "1" Employe : redigéPar

    Paiement "*" --> "1" Technicien : estVersePour
    Paiement "*" --> "1" DSI : valideParr

    Rapport "*" --> "1" DSI : genereParr

    StatistiqueTechnicien "1" --> "1" Technicien : concerneLe

    Materiel "*" --> "1" Ville : estLocaliséDans

    %% Dépendances Enums
    Incident ..> StatutIncident : utilise
    Incident ..> PrioriteIncident : utilise
    Incident ..> ComplexiteIncident : utilise
    Affectation ..> StatutAffectation : utilise
    Notification ..> TypeNotification : utilise
    Paiement ..> StatutPaiement : utilise
    Utilisateur ..> RoleUtilisateur : utilise
    Materiel ..> TypeMateriel : utilise